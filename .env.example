APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production example: https://getglamo.com
CORS_ALLOWED_ORIGINS=https://getglamo.com,https://www.getglamo.com,https://app.flutterflow.io

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# Push notifications (FCM)
PUSH_NOTIFICATIONS_ENABLED=true
PUSH_NOTIFICATIONS_PROVIDER=fcm_legacy

# FCM Legacy (deprecated by Firebase; keep for backward compatibility)
FCM_LEGACY_ENDPOINT=https://fcm.googleapis.com/fcm/send
FCM_SERVER_KEY=
FCM_TIMEOUT_SECONDS=10
FCM_CHUNK_SIZE=500

# FCM HTTP v1 (recommended)
FCM_V1_ENDPOINT_TEMPLATE=https://fcm.googleapis.com/v1/projects/{project_id}/messages:send
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
FCM_V1_SCOPE=https://www.googleapis.com/auth/firebase.messaging
FCM_V1_CHUNK_SIZE=100

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.getglamo.com
MAIL_PORT=465
MAIL_USERNAME=noreply@getglamo.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@getglamo.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_EHLO_DOMAIN=getglamo.com
MAIL_VERIFY_PEER=false

# BEEM SMS (OTP)
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SENDER_ID=Glamo
BEEM_DEFAULT_COUNTRY_CODE=255
BEEM_SMS_URL=https://apisms.beem.africa/v1/send
BEEM_OTP_APP_ID=3722
BEEM_OTP_REQUEST_URL=https://apiotp.beem.africa/v1/request
BEEM_OTP_VERIFY_URL=https://apiotp.beem.africa/v1/verify
BEEM_OTP_TTL_MINUTES=5
PROVIDER_ONBOARDING_ADMIN_EMAIL=info@getglamo.com
PROVIDER_ONBOARDING_ADMIN_PHONE=255743693885

GLAMO_WEBSITE_URL=https://getglamo.com
GLAMO_APP_STORE_URL=https://apps.apple.com/
GLAMO_PLAY_STORE_URL=https://play.google.com/store
GLAMO_SUPPORT_EMAIL=info@getglamo.com

# SNIPPE PAYMENTS
# Base URL (production): https://api.snippe.sh
SNIPPE_BASE_URL=https://api.snippe.sh
# Bearer API key used in: Authorization: Bearer <api_key>
SNIPPE_API_KEY=snp_87b1295d00bffee6dc16f1d992d94724c7312ba7518478c36440a7385bfc7662
# Webhook signing secret (HMAC-SHA256) used to verify X-Webhook-Signature
SNIPPE_WEBHOOK_SECRET=whsec_d348bde7d9f1b8832c5e4dc8c76f5dacc4230d2ecaccb29c6f36540c9d3859bd
# Optional override (must be HTTPS and publicly reachable by Snippe)
SNIPPE_WEBHOOK_URL=
# Reject webhooks older than this (seconds) to prevent replay attacks
SNIPPE_WEBHOOK_TOLERANCE=300
SNIPPE_TIMEOUT=30

# Pricing / Travel
GLAMO_FUEL_PRICE_PER_LITER=3200
GLAMO_MOTORBIKE_LITERS_PER_KM=0.03
GLAMO_TRAVEL_FIXED_FEE=2000
GLAMO_TRAVEL_ROUND_TO=100
GLAMO_PROVIDER_RADIUS_KM=10
GLAMO_USAGE_PERCENT=5
GLAMO_COMMISSION_PERCENT=10
GLAMO_PROVIDER_DEBT_BLOCK_THRESHOLD=10000
GLAMO_CHECKOUT_CASH_ROUND_TO=1000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
